# ─────────────────────────────────────────────────────────────────
#  AI Call Copilot — Configuration
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── AI Provider ───────────────────────────────────────────────────
# Choose one: gemini | anthropic | groq
AI_PROVIDER=anthropic

# ── AI Model ──────────────────────────────────────────────────────
# Anthropic models:  claude-sonnet-4-20250514 | claude-3-5-haiku-20241022 | claude-3-opus-20240229
# Gemini models:     gemini-2.0-flash | gemini-1.5-pro | gemini-1.5-flash
# Groq models:       llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768 | gemma2-9b-it
AI_MODEL=claude-sonnet-4-20250514

# ── API Keys (only the one matching AI_PROVIDER is required) ──────
ANTHROPIC_API_KEY=your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here
GROQ_API_KEY=your-groq-key-here

# ── Speech-to-Text (STT) Provider ─────────────────────────────────
# Choose one: faster-whisper | whisper
#   faster-whisper  →  runs locally, free, no API key needed
#   whisper         →  OpenAI Whisper API (requires OPENAI_API_KEY)
STT_PROVIDER=faster-whisper

# ── STT Model ─────────────────────────────────────────────────────
# faster-whisper models: tiny | base | small | medium | large-v2 | large-v3
# whisper API models:    whisper-1
STT_MODEL=base

# ── OpenAI Key (only needed if STT_PROVIDER=whisper) ──────────────
OPENAI_API_KEY=your-openai-key-here
